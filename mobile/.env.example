# Public Mapbox token (pk.*) — read at runtime, used for tiles/Directions/Static/Matching.
MAPBOX_ACCESS_TOKEN=pk.your_public_token_here

# Secret Mapbox download token (sk.* with DOWNLOADS:READ scope) — used at build time
# to fetch the native @rnmapbox/maps SDK. Set as an EAS secret in CI.
RNMAPBOX_DOWNLOAD_TOKEN=sk.your_download_token_here
